# Copy this file to an untracked `.env.local`, then replace every marked value.
# Docker Compose reads it only when passed with `--env-file .env.local`.
# ASP.NET Core does not load this file automatically; export its backend values in your shell.
# Never commit credentials or production secrets.

NODE_ENV=development
WEBSITE_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:5000
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=the_domain
POSTGRES_USER=the_domain
POSTGRES_PASSWORD=the_domain_local_password

# ASP.NET Core configuration overrides. Keep the real value in an untracked local environment.
Database__Enabled=true
Database__ConnectionString=Host=localhost;Port=5432;Database=the_domain;Username=the_domain;Password=the_domain_local_password
Database__CommandTimeoutSeconds=30

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

Cloudinary__Enabled=false
Cloudinary__CloudName=
Cloudinary__ApiKey=
Cloudinary__ApiSecret=
Cloudinary__FolderPrefix=the-domain
Cloudinary__MaxImageSizeMb=15
Cloudinary__MaxVideoSizeMb=100
# MIME arrays can be overridden with indexed ASP.NET configuration keys when needed.

Authentication__Enabled=true
Authentication__Issuer=the-domain-local
Authentication__Audience=the-domain-admin
Authentication__SigningKey=replace-with-local-strong-key-at-least-32-bytes
Authentication__AccessTokenLifetimeMinutes=30
Authentication__RefreshTokenLifetimeDays=7

InitialAdmin__Enabled=true
InitialAdmin__Email=admin@thedomain.local
InitialAdmin__Password=replace-with-strong-local-password
InitialAdmin__FullName=The Domain Super Admin
