{
  "Api": {
    "ApplicationName": "The Domain API",
    "Version": "1.0.0"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Database": {
    "Enabled": false,
    "ConnectionString": "",
    "CommandTimeoutSeconds": 30
  },
  "Authentication": {
    "Enabled": false,
    "Issuer": "",
    "Audience": "",
    "SigningKey": "",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 14
  },
  "InitialAdmin": {
    "Enabled": false,
    "Email": "",
    "Password": "",
    "FullName": ""
  },
  "Cloudinary": {
    "Enabled": false,
    "CloudName": "",
    "ApiKey": "",
    "ApiSecret": "",
    "FolderPrefix": "the-domain",
    "MaxImageSizeMb": 15,
    "MaxVideoSizeMb": 100,
    "AllowedImageMimeTypes": ["image/jpeg", "image/png", "image/webp"],
    "AllowedVideoMimeTypes": ["video/mp4", "video/webm"]
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  }
}
