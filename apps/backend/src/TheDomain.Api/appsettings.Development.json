{
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001"
    ]
  },
  "Database": {
    "Enabled": false,
    "ConnectionString": "",
    "CommandTimeoutSeconds": 30
  },
  "Authentication": {
    "Enabled": false,
    "Issuer": "TheDomain.Api.Local",
    "Audience": "TheDomain.Admin.Local",
    "SigningKey": ""
  },
  "InitialAdmin": {
    "Enabled": false
  },
  "Cloudinary": {
    "Enabled": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "System": "Warning"
      }
    }
  }
}
